import {POS_EVENT_NAMES} from '@shopify/ui-extensions/point-of-sale';
{% if flavor contains "typescript" %}
import type {
  CashTrackingSessionCompleteEvent,
  CashTrackingSessionStartEvent,
  TransactionCompleteEvent,
} from '@shopify/ui-extensions/point-of-sale';
import type {Api, ShopifyGlobal} from '@shopify/ui-extensions/pos.app.ready.data';
{% endif %}

export default ({% if flavor contains "typescript" %}_api: Api{% endif %}) => {
  const backgroundShopify = shopify{% if flavor contains "typescript" %} as ShopifyGlobal{% endif %};

  console.log('[pos-background] extension loaded');

  backgroundShopify.addEventListener(
    POS_EVENT_NAMES.TRANSACTION_COMPLETE,
    (event{% if flavor contains "typescript" %}: TransactionCompleteEvent{% endif %}) => {
      try {
        console.log('[pos-background] transaction complete', event);
      } catch (error) {
        console.error('[pos-background] transaction complete handler failed', error);
      }
    },
  );

  backgroundShopify.addEventListener(
    POS_EVENT_NAMES.CASH_TRACKING_SESSION_START,
    (event{% if flavor contains "typescript" %}: CashTrackingSessionStartEvent{% endif %}) => {
      try {
        console.log('[pos-background] cash tracking session start', event);
      } catch (error) {
        console.error('[pos-background] cash tracking session start handler failed', error);
      }
    },
  );

  backgroundShopify.addEventListener(
    POS_EVENT_NAMES.CASH_TRACKING_SESSION_COMPLETE,
    (event{% if flavor contains "typescript" %}: CashTrackingSessionCompleteEvent{% endif %}) => {
      try {
        console.log('[pos-background] cash tracking session complete', event);
      } catch (error) {
        console.error('[pos-background] cash tracking session complete handler failed', error);
      }
    },
  );
};
