    const servicePoints = externalApiDeliveryPoints.map(buildServicePoint);

    // Generate one fulfillment option per service point, for every input fulfillment.
    const operations: Operation[] = fulfillments.flatMap((fulfillment) =>
        servicePoints.map((servicePoint: ServicePoint) => ({
